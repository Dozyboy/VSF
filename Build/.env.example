# AgentCore Studio — environment variables. Copy to `.env` and fill in real values (never commit
# `.env` itself — see .gitignore). P1 stub set; extended per phase as wiring lands.

# --- Postgres (Decision #2 Postgres-everything, Decision #3 RLS fence) ---
# 2 role/DSN split, NOT 1: studio_owner (DDL + admin, bypasses RLS as table owner via
# get_admin_pool) vs studio_app (runtime DML only, RLS enforced via get_pool). Never point the
# app's runtime connection at studio_owner — that would silently disable the fence.
STUDIO_DATABASE_URL=postgresql://studio_app:changeme@localhost:5432/studio
STUDIO_DATABASE_URL_ADMIN=postgresql://studio_owner:changeme@localhost:5432/studio

# --- Gemini LLM provider (Decision #9 — shared infra, LLM-only; embedding stays AIE-1's seam) ---
STUDIO_GEMINI_API_KEY=changeme

# --- Feature flags ---
STUDIO_ENABLE_TRACING=false
STUDIO_USE_FAKE_PROVIDERS=true

# --- Langfuse (optional obs backend, `pip install .[obs]`) ---
STUDIO_LANGFUSE_PUBLIC_KEY=
STUDIO_LANGFUSE_SECRET_KEY=
STUDIO_LANGFUSE_HOST=
